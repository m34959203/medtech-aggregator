# База данных. По умолчанию SQLite (мгновенный запуск без Docker).
# Для Postgres: postgresql+psycopg2://medtech:medtech@localhost:5544/medtech
DATABASE_URL=sqlite:///./medtech.db

# LLM для нормализации услуг (Groq — быстрый и дешёвый).
# Если ключа нет — нормализация откатывается на fuzzy-match (работает без сети).
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# Чат-помощник (POST /api/chat). Провайдер OpenAI-совместимый.
# LLM_PROVIDER: auto (alem если есть ключ, иначе groq) / alem / groq.
# Без ключа провайдера бот деградирует в детерминированный поиск.
LLM_PROVIDER=auto
ALEM_API_KEY=
ALEM_BASE_URL=https://llm.alem.ai/v1
ALEM_MODEL=alemllm

# Порог уверенности нормализации, ниже которого услуга помечается на ручную проверку.
MATCH_CONFIDENCE_THRESHOLD=0.78

# Безопасность админ-зоны (passwordless). Секретный ключ доступа к /admin, ревью,
# экспорту, приёму данных. ПУСТО → админ-роуты ЗАКРЫТЫ (fail-closed).
# Сгенерировать: python -c "import secrets; print(secrets.token_urlsafe(32))"
# Вход: /admin?key=<ADMIN_TOKEN> (magic-link) либо ввод ключа в форме.
ADMIN_TOKEN=
# True за HTTPS в проде — cookie сессии только по TLS.
COOKIE_SECURE=false

# Rate-limit публичных POST (жалоба/лид/чат/корзина) и логина (анти-брутфорс).
# In-memory per-IP. Выключить можно только для отладки.
RATE_LIMIT_ENABLED=true

# WhatsApp-туннель (микросервис wa-gateway на Baileys). Бэкенд проксирует к нему.
# Пусто → WA-функции отключены (503). В docker-compose WA_GATEWAY_URL задан.
# Секреты: python -c "import secrets; print(secrets.token_hex(32))"
WA_GATEWAY_URL=
WA_API_SECRET=
WA_INBOUND_WEBHOOK_SECRET=
