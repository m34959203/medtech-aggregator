# Публичный origin фронта (на клиенте /api/* проксируется Next-ом на бэкенд).
NEXT_PUBLIC_API_URL=http://localhost:3000
# Прямой адрес бэкенда (SSR + rewrites /api → сюда).
INTERNAL_API_URL=http://localhost:8000

# Ключ Яндекс.Карт (JavaScript API). Публичный по своей природе — вшивается в бандл.
# Защита через ограничение по HTTP Referer в кабинете Яндекса, а не секретностью ключа.
# Кабинет: https://developer.tech.yandex.ru/  →  тариф «Бесплатный с ограничениями».
NEXT_PUBLIC_YANDEX_MAPS_API_KEY=your-yandex-js-api-key
